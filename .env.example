# ====== Neon Postgres ======
# 在 https://neon.tech 建立 project，複製 pooled connection string
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# ====== Pusher Channels ======
# 在 https://pusher.com 建立 Channels app，至 App Keys 取得以下資料
PUSHER_APP_ID="xxxxxxx"
PUSHER_SECRET="xxxxxxxxxxxxxxxx"
NEXT_PUBLIC_PUSHER_KEY="xxxxxxxxxxxxxxxx"
NEXT_PUBLIC_PUSHER_CLUSTER="ap3"

# ====== 一般設定 ======
NODE_ENV="development"

# ====== SEO ======
# 線上正式網域（會用在 metadata, sitemap, robots, OG image canonical URL）
# 沒設定的話會 fallback 到 Vercel 部署 URL 或 localhost
NEXT_PUBLIC_SITE_URL="https://yueyixia.com"
